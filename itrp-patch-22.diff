diff -Nrua --strip-trailing-cr '--exclude=.git' 0.8.22-orig/shaders/Lib/Programs/Setup/KernelFFT_CS.glsl 0.8.22-patched/shaders/Lib/Programs/Setup/KernelFFT_CS.glsl
