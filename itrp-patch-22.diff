+#endif
+
+#if CAP_LUMINANCE > -1
+  const float maxLuminance = float(1 << CAP_LUMINANCE);
+#endif
+
+// soft knee thresholding
+vec3 softKnee(vec3 color) {
+  float l = Luminance(color.rgb);
+  float x = max(0, l - BLOOM_THRESHOLD + BLOOM_KNEE);
+  color *= mix(x * x / (4 * BLOOM_KNEE), max(0, l - BLOOM_THRESHOLD), float(x > BLOOM_THRESHOLD + BLOOM_KNEE)) / max(l, 1e-6);
+  #if CAP_LUMINANCE > -1
+    color *= min(1.0, maxLuminance / l);
+  #endif
+  return color;
+}
