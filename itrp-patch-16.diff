+	const float angularRadius = SUN_ANGULAR_RADIUS * PI / 180.0;
 
-	float angle = facos(saturate(dot(worldDir, moonDir)));
+	float cosAngle = dot(worldDir, moonDir);
+	float angle = facos(clamp(cosAngle, -1.0, 1.0));
 
+	// Disc mask (soft edge)
 	float disc = float(angle <= angularRadius);
-	return (vec3(0.8886, 1.0019, 1.3095) * NIGHT_BRIGHTNESS) * disc;
+
+	float phaseAngle = float(4 + moonPhase) * (-PI / 4.0);
+
+
+	vec3 tangent = normalize(cross(moonDir, vec3(0.0, 1.0, 0.0)));
+	vec3 binormal = cross(moonDir, tangent);
+	vec3 dirDiff = worldDir - moonDir;
+
+	float u = dot(dirDiff, tangent);
+	float v = dot(dirDiff, binormal);
+
+	u = u / (2.0 * angularRadius) + 0.5;
+	v = -v / (2.0 * angularRadius) + 0.5;
+	vec2 moonUV = vec2(u, v);
+
+	vec2 pos = 2.0 * moonUV - 1.0;
+	float r2 = dot(pos, pos); // we got 'em r2
+
+	vec3 moonDirLocal = normalize(vec3(pos.x, pos.y, sqrt(1.0 - r2)));
+
+	vec3 moonDirWorld = moonDirLocal.x * tangent - moonDirLocal.y * binormal - moonDirLocal.z * moonDir;
+
+	vec3 phaseSunDir = normalize(moonDir * cos(phaseAngle) + binormal * sin(phaseAngle));
+
+	float terminator = dot(normalize(moonDirWorld), phaseSunDir);
+
+	// Soft sunlit side
+	float phaseLight = smoothstep(-0.1, 0.05, terminator);
+
+	// Earthshine (dark side glow)
+	// float earthshine = smoothstep(-0.6, -0.1, terminator) * 0.08;
+
+	vec3 moonColor = vec3(0.8886, 1.0019, 1.3095);
+	vec3 earthshineColor = vec3(0.6, 0.7, 1.0) * 0.01; // subtle blue
+
+	vec3 color =
+			moonColor * phaseLight +
+			earthshineColor * (1 - phaseLight);
+
+	return color * disc * (PHASED_NIGHT_BRIGHTNESS + mix(0, 0.00001, float(moonPhase == 4)));
 }
 
 
