+layout (local_size_x = 16, local_size_y = 16) in;
+
+// todo: taa without upscaling
+#ifdef CLOUD_TAAU_ENABLED
+	#if FSR2_SCALE == 0 || SR_ENABLE
+		const vec2 workGroupsRender = vec2(0.5, 0.5);
+	#elif FSR2_SCALE == 1
