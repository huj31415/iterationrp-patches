+--------------------------------------------------------------------------------
+*/
+
+#define PASS_CLOUD_SM
+
+layout (local_size_x = 16, local_size_y = 16) in;
+const ivec3 workGroups = ivec3(32, 32, 1);
+
+#include "/Lib/Utilities.glsl"
+#include "/Lib/UniformDeclare.glsl"
+
+#include "/Lib/clouds/Common.glsl"
+#include "/Lib/clouds/Shadows.glsl"
+
+writeonly uniform image2D cloudShadowImg;
+
+const ivec2 checkerboardOffset4x4[16] = ivec2[16](
+	ivec2(0, 0), ivec2(2, 0), ivec2(0, 2), ivec2(2, 2),
+	ivec2(1, 1), ivec2(3, 1), ivec2(1, 3), ivec2(3, 3),
+	ivec2(1, 0), ivec2(3, 0), ivec2(1, 2), ivec2(3, 2),
+	ivec2(0, 1), ivec2(2, 1), ivec2(0, 3), ivec2(2, 3)
+);
+
+vec2 ReprojectShadow(vec2 uv) {
+	vec3 worldPos = SetupCloudShadowPos(uv);
+	vec3 prevPos = transMAD(cloud.prevShadowViewProj, worldPos);
+	// prevPos *= rcp(length(prevPos.xy) * 0.5 + 0.5);
+	return prevPos.xy * 0.5 + 0.5;
+}
+
+const vec2 rSize = vec2(1.0 / 512.0); // rcp(textureSize(cloudShadowTex, 0))
+const float r256 = 1.0 / 256.0;
+
+const float windAngle = radians(CLOUD_LOW_WIND_ANGLE);
+const vec3 windDir = vec3(cos(windAngle), 0.5, sin(windAngle));
+const vec3 windVelocity = windDir * CLOUD_LOW_WIND_SPEED;
+
+uniform vec3 cameraMovement;
+
+//======// Main //================================================================================//
+void main() {
+	ivec2 tid = ivec2(gl_GlobalInvocationID.xy);
+
+	// Checkerboard render cloud shadow map
+	ivec2 offset = checkerboardOffset4x4[frameCounter & 15];
+	if (true || (tid & 3) == offset || cloud.historyReset) {
+		vec2 uv = (vec2(tid) + 0.5) * rSize;
+
+		vec2 dither = BlueNoiseTemporal(tid);
+		vec3 rayPos = SetupCloudShadowPos(uv + (dither - 0.5) * rSize);
+		vec3 cloudPos;
+		float cloudShadow = CalculateCloudShadows(rayPos, dither.x, cloudPos);
+
+		// for low clouds
+		vec3 motionVector = -windVelocity;
+		motionVector *= cloud.worldTimeDiff * 0.05;
+		motionVector += cameraMovement;
+
+		// Reproject and accumulate
+		vec2 prevUV = transMAD(cloud.prevShadowViewProj, cloudPos).xy;
+		prevUV *= rcp(length(prevUV) * 0.5 + 0.5);
+		prevUV = prevUV * 0.5 + 0.5;
+		
+		// get previous cloud shadow and frame index
+		vec2 prevValue = textureLod(cloudShadowTex, prevUV, 0).xy;
+		float frameIdx = min(fma(prevValue.y, 256.0, 1.0), 16.0);
+		if (saturate(prevUV) == prevUV && prevValue.x < 1 && frameIdx > 2.0 && !cloud.historyReset) { //  && shadowModelViewInverse2.y > 0.02
+			float weight = rcp(frameIdx);
+			cloudShadow = mix(prevValue.x, cloudShadow, weight);
+		}
+		barrier();
+		imageStore(cloudShadowImg, tid, vec4(cloudShadow, frameIdx * r256, 0.0, 0.0));
+	}
+}
