+				#else
+					sh = depthGradient > -viewPos.z * 0.002 + 0.005;
+				#endif
+
+				float distDiff = (sampleViewPos.z - stepViewPos.z) * distThreshold;
+				sh = sh && (dot(normalize(posDiff), viewRayDir) > 0.99 || saturate(distDiff) == distDiff);
