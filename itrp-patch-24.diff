--- 0.8.24-orig/shaders/Lib/Programs/Setup/KernelFFT_CS.glsl	1969-12-31 19:00:00.000000000 -0500
+++ 0.8.24-patched/shaders/Lib/Programs/Setup/KernelFFT_CS.glsl	2026-07-11 22:20:52.151776800 -0400
@@ -0,0 +1,81 @@
+// by huj31415
+
+// run once on shader load or window resize
+// compute FFT of diffraction kernel and write to image
+
+#include "/Lib/UniformDeclare.glsl"
+#include "/Lib/Utilities.glsl"
+
+#include "/Lib/BasicFunctions/FFT.glsl"
+
+// N rows, N/4 threads per row
+const ivec3 workGroups = ivec3(1, FFT_SIZE, 1);
+layout (local_size_x = N_4_1, local_size_y = 1) in;
+
+#ifdef ROW
+// Row pass ===================================================================
+
+uniform sampler2D ker;
+layout (rgba32f) uniform writeonly image2D tmpFFT;
+
+// pads and scales kernel texture for FFT input
+vec4 sampleCenterKernel(uint x, uint y) {
+  // map thread coordinates to signed distance from the FFT origin
+  int sx = int(x);
+  int sy = int(y);
+  if (sx >= int(FFT_SIZE / 2)) sx -= int(FFT_SIZE);
+  if (sy >= int(FFT_SIZE / 2)) sy -= int(FFT_SIZE);
+
+  // check if thread falls outside the target bloom size
+  int halfK = KERNEL_SIZE / 2;
+  if (abs(sx) >= halfK || abs(sy) >= halfK) {
+    return vec4(0.0);
+  }
+
+  // map the signed offset directly out from the texture center
+  vec2 uv = 0.5 + vec2(sx, sy) / float(KERNEL_SIZE);
+
+  return textureLod(ker, uv, 0.0);
+}
+
+void main() {
+  uint y = gl_GlobalInvocationID.y;
+  uint x = gl_GlobalInvocationID.x;
+
+  vec4 t0 = sampleCenterKernel(x, y);
+  vec4 t1 = sampleCenterKernel(x + N_4_1, y);
+  vec4 t2 = sampleCenterKernel(x + N_4_2, y);
+  vec4 t3 = sampleCenterKernel(x + N_4_3, y);
+
+  rgba1DFFT(x, t0, t1, t2, t3);
+
+  imageStore(tmpFFT, ivec2(y, x),         t0);
+  imageStore(tmpFFT, ivec2(y, x + N_4_1), t1);
+  imageStore(tmpFFT, ivec2(y, x + N_4_2), t2);
+  imageStore(tmpFFT, ivec2(y, x + N_4_3), t3);
+}
+
+#else
+// Column pass ================================================================
+
+layout (rgba32f) uniform image2D tmpFFT;
+layout (rgba32f) uniform writeonly image2D kerFFT;
+
+void main() {
+  uint y = gl_GlobalInvocationID.y;
+  uint x = gl_GlobalInvocationID.x;
+
+  vec4 t0 = imageLoad(tmpFFT, ivec2(x, y));
+  vec4 t1 = imageLoad(tmpFFT, ivec2(x + N_4_1, y));
+  vec4 t2 = imageLoad(tmpFFT, ivec2(x + N_4_2, y));
+  vec4 t3 = imageLoad(tmpFFT, ivec2(x + N_4_3, y));
+
+  rgba1DFFT(x, t0, t1, t2, t3);
+
+  imageStore(kerFFT, ivec2(y, x),         t0 * NORM);
+  imageStore(kerFFT, ivec2(y, x + N_4_1), t1 * NORM);
+  imageStore(kerFFT, ivec2(y, x + N_4_2), t2 * NORM);
+  imageStore(kerFFT, ivec2(y, x + N_4_3), t3 * NORM);
+}
+
+#endif
\ No newline at end of file
