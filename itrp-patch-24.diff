+vec4 IrradianceCache(ivec3 ircTexel, ivec3 voxelTexel, ivec3 cameraPositionIntToPrevious){
+	vec4 ircColor = vec4(0.0, 0.0, 0.0, 1.0);
+
+	vec4 currVoxelData = texelFetch(voxelData3D, voxelTexel, 0);
