+	#elif FSR2_SCALE == 2
+		const vec2 workGroupsRender = vec2(0.2941, 0.2941);
+	#elif FSR2_SCALE == 3
+		const vec2 workGroupsRender = vec2(0.25, 0.25);
+	#elif FSR2_SCALE == 4
+		const vec2 workGroupsRender = vec2(0.1667, 0.1667);
+	#endif
+#else
+	#if FSR2_SCALE == 0
+		const vec2 workGroupsRender = vec2(1.0, 1.0);
+	#elif FSR2_SCALE == 1
+		const vec2 workGroupsRender = vec2(0.6667, 0.6667);
+	#elif FSR2_SCALE == 2
+		const vec2 workGroupsRender = vec2(0.5882, 0.5882);
+	#elif FSR2_SCALE == 3
+		const vec2 workGroupsRender = vec2(0.5, 0.5);
+	#elif FSR2_SCALE == 4
+		const vec2 workGroupsRender = vec2(0.3333, 0.3333);
+	#endif
+#endif
+
+writeonly uniform image2D cloudOriginImg;
+
+#include "/Lib/clouds/Common.glsl"
+#include "/Lib/clouds/Render.glsl"
+
+// Remap thread index to 2D index following Z-order curve.
+uvec2 RemapThread8x8(uint idx) {
+	return uvec2((((idx >> 2) & 0x7) & 0xFFFE) | (idx & 0x1), ((idx >> 1) & 0x3) | (((idx >> 3) & 0x7) & 0xFFFC));
+}
+
+uvec2 RemapThread16x16(uint idx) {
+	return RemapThread8x8(idx & 63) + (uvec2((idx >> 6) & 1, idx >> 7) << 3);
+}
+
+uvec4 Unpack2xU8_ID_Y_from_vec4(vec4 x){
+	return (uvec4(x * 65535.0) & 127u);
+}
+
+bool SkyCheck4x4(vec2 coord) {
+	// 4x4 pixel neighborhood using textureGatherOffset
+	uvec4 check = Unpack2xU8_ID_Y_from_vec4(textureGatherOffset(FBTEX_GSOLID_DATA, coord, ivec2(-2, -2), 2));
+	check &= Unpack2xU8_ID_Y_from_vec4(textureGatherOffset(FBTEX_GSOLID_DATA, coord, ivec2(-2,  2), 2));
+	check &= Unpack2xU8_ID_Y_from_vec4(textureGatherOffset(FBTEX_GSOLID_DATA, coord, ivec2( 2, -2), 2));
+	check &= Unpack2xU8_ID_Y_from_vec4(textureGatherOffset(FBTEX_GSOLID_DATA, coord, ivec2( 2,  2), 2));
+
+	// MATID_SKY = 0
+	return any(equal(check, uvec4(MATID_SKY)));
+}
+// #include "/Lib/Uniform/GbufferTransforms.glsl"
+//======// Main //================================================================================//
+void main() {
+	uvec2 localPos = RemapThread16x16(gl_LocalInvocationIndex);
+	ivec2 texelPos = ivec2(localPos + gl_WorkGroupID.xy * gl_WorkGroupSize.xy);
+
+	vec2 coord = ((vec2(texelPos) + 0.5) * UNIFORM_PIXEL_SIZE);
+
+	#ifdef CLOUD_TAAU_ENABLED
+		vec2 renderCoord = (coord + UNIFORM_TAA_JITTER * 0.5) * CLOUD_TAAU_SCALE;
+		ivec2 scaledTexelPos = texelPos * CLOUD_TAAU_SCALE;
+		vec2 rawDepthCoord = CLOUD_TAAU_SCALE * (vec2(texelPos) + 0.5);
+	#else
+		#define renderCoord coord
+		#define scaledTexelPos texelPos
+		vec2 rawDepthCoord = (vec2(texelPos) + 0.5);
+	#endif
+#if SR_ENABLE
+	  if(any(greaterThan(renderCoord, vec2(1)))) return;
+#endif
+// /*
+	// vec4 depth = textureGather(depthtex1, pixelSize * rawDepthCoord, 0);
+	// vec3 viewPos = ViewPos_From_ScreenPos(rawDepthCoord, minOf(depth));
+	// #ifdef LOD_RENDERING
+	// 	if (all(equal(vec4(1.0), depth))) {
+			
+	// 		depth = ScreenDepth_From_LODScreenDepth(textureGather(LOD_DEPTH_TEX_1, UNIFORM_PIXEL_SIZE * rawDepthCoord, 0));
+	// 		viewPos = ViewPos_From_ScreenPos_LOD(rawDepthCoord, minOf(depth));
+	// 	}
+	// #endif
+// */
+	// x: sunlight, y: skylight, z: depth, w: transmittance
+	vec4 cloudOut = vec4(0.0, 0.0, 0.0, 1.0);
+
+	//if (any(equal(vec4(1.0), depth))) {
+	if (SkyCheck4x4(pixelSize * rawDepthCoord)) {
+		vec2 noise = BlueNoiseTemporal(texelPos); //SampleStbnVec2(texelPos, frameCounter + 11);
+
+		vec3 viewDir  = ScreenToViewDirRaw(renderCoord);
+		vec3 worldDir = mat3(gbufferModelViewInverse) * viewDir;
+
+		cloudOut = RenderClouds(worldDir, noise);
+	}
+
+	imageStore(cloudOriginImg, texelPos, cloudOut);
+}
