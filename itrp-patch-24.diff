+vec3 getConvBloom(vec2 coord) {
+	vec2 coordScale = vec2(1.0 - float(KERNEL_SIZE) / float(FFT_SIZE));
+
+	// Determine bounding box dimensions based on aspect ratio
+	if (aspectRatio >= 1.0) {
+		coordScale.y /= aspectRatio;
+	} else {
+		coordScale.x *= aspectRatio;
+	}
+	return max(vec3(0.0), textureLod(FFTout, 1.0 - (coord - 2) * pixelSize * coordScale, 0).rgb);
+}
