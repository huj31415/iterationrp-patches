diff -Nrua --strip-trailing-cr '--exclude=.git' '--exclude=texture' 0.8.24-orig/shaders/Lib/BasicFunctions/FFT.glsl 0.8.24-patched/shaders/Lib/BasicFunctions/FFT.glsl
--- 0.8.24-orig/shaders/Lib/BasicFunctions/FFT.glsl	1969-12-31 19:00:00.000000000 -0500
+++ 0.8.24-patched/shaders/Lib/BasicFunctions/FFT.glsl	2026-07-11 20:30:22.063437200 -0400
@@ -0,0 +1,128 @@
+// by huj31415
+
+#define PI 3.1415926535
+#define TAU 6.283185307
+
+#if FFT_SIZE == 1024
+  #define N_4_1 256 // N / 4
+  #define N_4_2 512 // 2N / 4
+  #define N_4_3 768 // 3N / 4
+  #define START_Ns 4
+#elif FFT_SIZE == 2048
+  #define N_4_1 512
+  #define N_4_2 1024
+  #define N_4_3 1536
+  #define START_Ns 8
+#endif
+
+#ifdef IFFT
+  #define INV -1.0
+#else
+  #define INV 1.0
+#endif
+
+const float NORM = 1.0 / float(FFT_SIZE);
+  
+shared vec2 row[FFT_SIZE];
+
+vec2 cmul(in vec2 A, in vec2 B) {
+  return vec2(A.x * B.x - A.y * B.y, dot(A, B.yx));
+}
+
+// to prevent shared bank conflicts
+uint swizzle(uint x) {
+  return (x & ~31) | ((x & 31) ^ ((x >> 5) & 31));
+}
+
+uint digit_reverse_4(uint x) {
+  return ((x & 3) << 8) | ((x & 12) << 4) | (x & 48) | ((x & 192) >> 4) | ((x >> 8) & 3);
+}
+
+// in-place Cooley-Tukey FFT, forward if inv = 1, inverse if inv = -1
+void fftR4_CT(uint x, uint Ns) {
+  uint Ns4 = Ns >> 2; // Ns / 4
+  uint offset = x & (Ns4 - 1u); // x % Ns4;
+
+  uint base = (x / Ns4) * Ns + offset; // floor(x / Ns4) * Ns + offset;
+  uint i0 = swizzle(base);
+  uint i1 = swizzle(base + Ns4);
+  uint i2 = swizzle(base + Ns4 * 2);
+  uint i3 = swizzle(base + Ns4 * 3);
+
+  // replace with shared memory LUT
+  float angle = -INV * TAU * (float(offset) / float(Ns));
+  vec2 w1 = vec2(cos(angle), sin(angle));
+
+  vec2 t0 = row[i0];
+  vec2 t1 = cmul(w1, row[i1]);
+  vec2 w2 = cmul(w1, w1);
+  vec2 t2 = cmul(w2, row[i2]);
+  vec2 t3 = cmul(cmul(w2, w1), row[i3]);
+
+  row[i0] = t0 + t1 + t2 + t3;
+  row[i1] = t0 - t2 + vec2(t1.y - t3.y, t3.x - t1.x) * INV;
+  row[i2] = t0 - t1 + t2 - t3;
+  row[i3] = t0 - t2 + vec2(t3.y - t1.y, t1.x - t3.x) * INV;
+}
+
+// avoid passing x0-x3 to reduce register pressure, only pass x and compute others inside the function
+void rgba1DFFT(uint x, inout vec4 t0, inout vec4 t1, inout vec4 t2, inout vec4 t3) {
+  #if FFT_SIZE == 2048
+    // load rg as real and imag and do radix 2 prepass
+    uint p00 = digit_reverse_4(x) << 1;
+    row[swizzle(p00)]     = t0.rg + t2.rg;
+    row[swizzle(p00 + 1)] = t0.rg - t2.rg;
+
+    uint p01 = digit_reverse_4(x + N_4_1) << 1;
+    row[swizzle(p01)]     = t1.rg + t3.rg;
+    row[swizzle(p01 + 1)] = t1.rg - t3.rg;
+  #else
+    // load rg as real and imag
+    row[swizzle(digit_reverse_4(x))] = t0.rg;
+    row[swizzle(digit_reverse_4(x + N_4_1))] = t1.rg;
+    row[swizzle(digit_reverse_4(x + N_4_2))] = t2.rg;
+    row[swizzle(digit_reverse_4(x + N_4_3))] = t3.rg;
+  #endif
+  barrier();
+
+  for (uint Ns = START_Ns; Ns <= FFT_SIZE; Ns <<= 2) {
+    fftR4_CT(x, Ns);
+    barrier();
+  }
+
+  // store rg fft output
+  t0.rg = row[swizzle(x)];
+  t1.rg = row[swizzle(x + N_4_1)];
+  t2.rg = row[swizzle(x + N_4_2)];
+  t3.rg = row[swizzle(x + N_4_3)];
+  barrier();
+
+  #if FFT_SIZE == 2048
+    // load ba as real and imag and do radix 2 prepass
+    uint p10 = digit_reverse_4(x) << 1;
+    row[swizzle(p10)]     = t0.ba + t2.ba;
+    row[swizzle(p10 + 1)] = t0.ba - t2.ba;
+
+    uint p11 = digit_reverse_4(x + N_4_1) << 1;
+    row[swizzle(p11)]     = t1.ba + t3.ba;
+    row[swizzle(p11 + 1)] = t1.ba - t3.ba;
+  #else
+    // load ba as real and imag
+    row[swizzle(digit_reverse_4(x))] = t0.ba;
+    row[swizzle(digit_reverse_4(x + N_4_1))] = t1.ba;
+    row[swizzle(digit_reverse_4(x + N_4_2))] = t2.ba;
+    row[swizzle(digit_reverse_4(x + N_4_3))] = t3.ba;
+  #endif
+  barrier();
+
+  for (uint Ns = START_Ns; Ns <= FFT_SIZE; Ns <<= 2) {
+    fftR4_CT(x, Ns);
+    barrier();
+  }
+
+  // store ba fft output
+  t0.ba = row[swizzle(x)];
+  t1.ba = row[swizzle(x + N_4_1)];
+  t2.ba = row[swizzle(x + N_4_2)];
+  t3.ba = row[swizzle(x + N_4_3)];
+}
\ No newline at end of file
diff -Nrua --strip-trailing-cr '--exclude=.git' '--exclude=texture' 0.8.24-orig/shaders/Lib/BasicFunctions/GameplayEffects.glsl 0.8.24-patched/shaders/Lib/BasicFunctions/GameplayEffects.glsl
--- 0.8.24-orig/shaders/Lib/BasicFunctions/GameplayEffects.glsl	1969-12-31 19:00:00.000000000 -0500
+++ 0.8.24-patched/shaders/Lib/BasicFunctions/GameplayEffects.glsl	2026-07-20 17:00:43.376611400 -0400
@@ -0,0 +1,124 @@
+// from https://github.com/Merlin1809/Eclipse-Shader/blob/Unstable/shaders/lib/gameplay_effects.glsl
+
+uniform float currentPlayerHealth;
+uniform float maxPlayerHealth;
+uniform float oneHeart;
+uniform float threeHeart;
+
+uniform float CriticalDamageTaken;
+uniform float MinorDamageTaken;
+
+uniform float exitWater;
+uniform float enterWater;
+uniform float exitLava;
+// uniform float exitPowderSnow;
+// uniform int isEyeInWater;
+
+// uniform float currentPlayerHunger;
+// uniform float maxPlayerHunger;
+
+// uniform float currentPlayerArmor;
+// uniform float maxPlayerArmor;
+
+// uniform float currentPlayerAir;
+// uniform float maxPlayerAir;
+
+// uniform bool is_sneaking;
+// uniform bool is_sprinting;
+// uniform bool is_hurt;
+// uniform bool is_invisible;
+// uniform bool is_burning;
+
+// uniform bool is_on_ground;
+// uniform bool isSpectator;
+
+void applyGameplayEffects(inout vec3 color, in vec2 texcoord, float noise){
+   
+    // detect when health is zero
+    bool isDead = currentPlayerHealth * maxPlayerHealth <= 0.0 && currentPlayerHealth > -1;
+
+    float distortmask = 0.0;
+    float vignette = sqrt(clamp(dot(texcoord*2.0 - 1.0, texcoord*2.0 - 1.0) * 0.5, 0.0, 1.0));
+
+    //////////////////////// DAMAGE DISTORTION /////////////////////
+    #if defined LOW_HEALTH_EFFECT || defined DAMAGE_TAKEN_EFFECT   
+        float heartBeat = (pow(sin(1 + 2*sin(frameTimeCounter * 10))*0.5+0.5,2.0)*0.2 + 0.1) ;
+        
+        // apply low health distortion effects
+        float damageDistortion = vignette * noise * heartBeat * threeHeart;
+        
+        // apply critical hit distortion effect
+        damageDistortion = mix(damageDistortion, vignette * (0.5 + noise), CriticalDamageTaken) * MOTION_AMOUNT;
+        
+        // apply death distortion effect
+        distortmask = damageDistortion; // isDead ? vignette * (0.7 + noise*0.3) : 
+    #endif
+    //////////////////////// WATER DISTORTION /////////////////////
+    #ifdef WATER_ON_CAMERA_EFFECT
+        if(exitWater > 0.0){
+            vec3 scale = vec3(1.0,1.0,0.0);
+            bool eyeInWater = isEyeInWater == 1;
+            scale.xy = (eyeInWater ? vec2(0.3) : vec2(0.5, 0.25 + (exitWater*exitWater)*0.25 ) ) * vec2(aspectRatio,1.0);
+            scale.z = eyeInWater ? 0.0 : exitWater;
+
+
+            float waterDrops = 0.0;
+            if(!eyeInWater) waterDrops = texture(noisetex, (texcoord - vec2(0.0, scale.z)) * scale.xy).b;
+            if(isEyeInWater == 0 && exitWater > 0.0) waterDrops = sqrt(min(max(waterDrops - (1.0-sqrt(exitWater)),0.0) * (1.0 + exitWater),1.0)) * WATER_ON_CAMERA_STRENGTH;
+
+            // apply distortion effects for exiting water and under water
+            distortmask = max(distortmask, waterDrops);
+        }
+        // if(enterWater > 0.0){
+        //     vec2 zoomTC = 0.5 + (texcoord - 0.5) * (sqrt(1.0-enterWater));
+        //     float waterSplash = texture(noisetex, zoomTC * vec2(aspectRatio,1.0)).a * (1.0-enterWater);
+
+        //     distortmask = max(distortmask, waterSplash);
+        // }
+    #endif
+    //////////////////////// HEAT DISTORTION /////////////////////
+    #ifdef ON_FIRE_DISTORT_EFFECT
+      if(exitLava > 0.0){
+            vec2 zoomin = 0.5 + (texcoord - 0.5) * (1.0-pow(1.0-clamp(-texcoord.y*0.5+0.75,0.0,1.0),1.0)) * (1.0-pow(1.0-exitLava,2.0));
+
+            vec2 UV = zoomin;
+
+            float flameDistort = texture(noisetex,  UV * vec2(aspectRatio,1.0) - vec2(0.0,frameTimeCounter*0.3)).b * clamp(-texcoord.y*0.3+0.3,0.0,1.0) * ON_FIRE_DISTORT_EFFECT_STRENGTH * exitLava;
+
+            distortmask = max(distortmask, flameDistort);
+        }
+    #endif
+
+    //////////////////////// APPLY DISTORTION /////////////////////
+    // all of the distortion will be based around zooming the UV in the center
+    vec2 zoomUV = 0.5 + (texcoord - 0.5) * (1.0 - distortmask);
+    
+    vec3 distortedColor = texture(FBTEX_MAIN_OUTPUT, zoomUV).rgb;
+
+    #if defined WATER_ON_CAMERA_EFFECT || defined ON_FIRE_DISTORT_EFFECT
+        // apply the distorted water color to the scene, but revert back to before when it ends
+        if(exitWater > 0.01 || exitLava > 0.01) color = distortedColor;
+    #endif
+
+
+    //////////////////////// APPLY COLOR EFFECTS /////////////////////
+    #if defined LOW_HEALTH_EFFECT || defined DAMAGE_TAKEN_EFFECT   
+        vec3 distortedColorLuma =  vec3(1.0, 0.0, 0.0) * dot(distortedColor, vec3(0.21, 0.72, 0.07));
+    
+        #ifdef LOW_HEALTH_EFFECT
+            float colorLuma = dot(color, vec3(0.21, 0.72, 0.07));
+
+            vec3 LumaRedEdges = mix(vec3(colorLuma), vec3(1.0, 0.3, 0.3) * distortedColorLuma.r, vignette);
+
+            // apply color effects for when you are at low health
+            color = mix(color, LumaRedEdges, mix(vignette * threeHeart, oneHeart, oneHeart));
+        #endif
+
+        #ifdef DAMAGE_TAKEN_EFFECT
+            color = mix(color, distortedColorLuma, vignette * sqrt(min(MinorDamageTaken,1.0)));
+            // color = mix(color, distortedColorLuma, sqrt(CriticalDamageTaken));
+        #endif
+
+        // if(isDead) color = distortedColorLuma * 0.35;
+    #endif
+}
\ No newline at end of file
