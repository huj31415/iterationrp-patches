diff -Nrua --strip-trailing-cr '--exclude=.git' '--exclude=texture' 0.8.24-orig/shaders/Lib/Programs/Composite/ImageConvolveIFFT_CS.glsl 0.8.24-patched/shaders/Lib/Programs/Composite/ImageConvolveIFFT_CS.glsl
