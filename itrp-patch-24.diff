+
+	if (abs(currVoxelID) > 1.0 && clamp(voxelTexel, ivec3(1), voxelResolutionInt - 2) == voxelTexel){
+		ircColor.a = float(
+			//abs(currVoxelID - 6.5) < 2.0 ||
+			abs(currVoxelID - 36.5) < 12.0 ||
+			currVoxelID == 56.0 ||
+			currVoxelID == 59.0 ||
+			currVoxelID == 65.0
+		) * 2.0 - 1.0;
+
+		float skylight = 0.0;
+ 
+		vec4 closeVoxelData = texelFetch(voxelData3D, voxelTexel + ivec3(0, 0, -1), 0);
