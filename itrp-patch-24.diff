+		if (bottomIntersection.y < 0.0) {
+			intersection.x = max0(topIntersection.x);
+			intersection.y = topIntersection.y;
+		} else if (bottomIntersection.x < 0.0) {
+			intersection.x = bottomIntersection.y;
+			intersection.y = topIntersection.y;
+		} else {
+			intersection.x = max0(topIntersection.x);
+			intersection.y = bottomIntersection.x;
