--- 0.8.24-orig/shaders/Lib/Programs/Composite/ImageFFT_CS.glsl	1969-12-31 19:00:00.000000000 -0500
+++ 0.8.24-patched/shaders/Lib/Programs/Composite/ImageFFT_CS.glsl	2026-07-11 22:41:39.894600900 -0400
@@ -0,0 +1,95 @@
+// by huj31415
+
+// run once per frame
+// compute FFT of image and write to image
+
+#include "/Lib/UniformDeclare.glsl"
+#include "/Lib/Utilities.glsl"
+
+#include "/Lib/BasicFunctions/FFT.glsl"
+
+// N rows, N/4 threads per row
+const ivec3 workGroups = ivec3(1, FFT_SIZE, 1);
+layout (local_size_x = N_4_1, local_size_y = 1) in;
+
+#ifdef ROW
+// Row pass ===================================================================
+
+// FBTEX_MAIN_OUTPUT already declared in UniformDeclare.glsl
+layout (rgba32f) uniform writeonly image2D tmpFFT;
+
+float GetExposureValue(){
+	return texelFetch(pixelData2D, ivec2(PIXELDATA_EXPOSURE, 0), 0).y;
+}
+
+#if CAP_LUMINANCE > -1
+  const float maxLuminance = float(1 << CAP_LUMINANCE);
+#endif
+
+// soft knee thresholding
+vec4 softKnee(vec4 color) {
+  float l = Luminance(color.rgb);
+  float x = max(0, l - BLOOM_THRESHOLD + BLOOM_KNEE);
+  color.rgb *= mix(x * x / (4 * BLOOM_KNEE), max(0, l - BLOOM_THRESHOLD), float(x > BLOOM_THRESHOLD + BLOOM_KNEE)) / max(l, 1e-6);
+  #if CAP_LUMINANCE > -1
+    color *= min(1.0, maxLuminance / l);
+  #endif
+  return color;
+}
+
+// downsample and pad scene texture into the FFT workspace with correct aspect ratio
+vec4 sampleThresholdedSceneTex(uint x, uint y) {
+  float maxDim = float(FFT_SIZE - KERNEL_SIZE);
+  vec2 size = aspectRatio >= 1.0 ? vec2(maxDim, maxDim / aspectRatio) : vec2(maxDim * aspectRatio, maxDim);
+  // zero pad outside valid image region
+  if (any(greaterThanEqual(vec2(x, y), size))) {
+    return vec4(0.0);
+  }
+
+  // map thread coordinates to uv
+  vec2 uv = (vec2(x, y) + 0.5) / size;
+
+  return softKnee(vec4(textureLod(FBTEX_MAIN_OUTPUT, uv, 0).rgb, 0) * GetExposureValue());
+}
+
+void main() {
+  uint y = gl_GlobalInvocationID.y;
+  uint x = gl_GlobalInvocationID.x;
+
+  vec4 t0 = sampleThresholdedSceneTex(x, y);
+  vec4 t1 = sampleThresholdedSceneTex(x + N_4_1, y);
+  vec4 t2 = sampleThresholdedSceneTex(x + N_4_2, y);
+  vec4 t3 = sampleThresholdedSceneTex(x + N_4_3, y);
+
+  rgba1DFFT(x, t0, t1, t2, t3);
+
+  imageStore(tmpFFT, ivec2(y, x),         t0);
+  imageStore(tmpFFT, ivec2(y, x + N_4_1), t1);
+  imageStore(tmpFFT, ivec2(y, x + N_4_2), t2);
+  imageStore(tmpFFT, ivec2(y, x + N_4_3), t3);
+}
+
+#else
+// Column pass ================================================================
+
+layout (rgba32f) uniform image2D tmpFFT;
+layout (rgba32f) uniform writeonly image2D imgFFT;
+
+void main() {
+  uint y = gl_GlobalInvocationID.y;
+  uint x = gl_GlobalInvocationID.x;
+
+  vec4 t0 = imageLoad(tmpFFT, ivec2(x, y));
+  vec4 t1 = imageLoad(tmpFFT, ivec2(x + N_4_1, y));
+  vec4 t2 = imageLoad(tmpFFT, ivec2(x + N_4_2, y));
+  vec4 t3 = imageLoad(tmpFFT, ivec2(x + N_4_3, y));
+
+  rgba1DFFT(x, t0, t1, t2, t3);
+
+  imageStore(imgFFT, ivec2(y, x),         t0 * NORM);
+  imageStore(imgFFT, ivec2(y, x + N_4_1), t1 * NORM);
+  imageStore(imgFFT, ivec2(y, x + N_4_2), t2 * NORM);
+  imageStore(imgFFT, ivec2(y, x + N_4_3), t3 * NORM);
+}
+
+#endif
