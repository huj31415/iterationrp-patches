+vec2 weatherHash(vec2 seed)
+{
+	uvec2 state = floatBitsToUint(seed + 1) * 747796405u + 2891336453u;
+	uvec2 word = ((state >> ((state >> 28u) + 4u)) ^ state) * 277803737u;
+	vec2 x = vec2((word >> 22u) ^ word) * (1.0 / float(0xFFFFFFFFu));
+	return x - COVERAGE_BIAS * x * (x - 1);
+}
