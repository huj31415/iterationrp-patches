+// layout (rgba32f) uniform image2D imgFFT;
+uniform sampler2D FFTout;
+
+vec3 getConvBloom(vec2 coord) {
+	vec2 coordScale = vec2(1.0 - float(KERNEL_SIZE) / float(FFT_SIZE));
+
+	// Determine bounding box dimensions based on aspect ratio
+	if (aspectRatio >= 1.0) {
+		coordScale.y /= aspectRatio;
+	} else {
+		coordScale.x *= aspectRatio;
+	}
+	return max(vec3(0.0), texture2D(FFTout, 1.0 - (coord - 2) * pixelSize * coordScale).rgb);
+}
+
+#if defined DIMENSION_OVERWORLD
+	const int ConvBloomStrength = (1 << CONV_BLOOM_STRENGTH);
+#elif defined DIMENSION_END
+	const int ConvBloomStrength = (1 << CONV_BLOOM_STRENGTH_END);
+#else
+	const int ConvBloomStrength = (1 << CONV_BLOOM_STRENGTH_NETHER);
+#endif
+
+#if CAP_LUMINANCE > -1
+  const float maxLuminance = float(1 << CAP_LUMINANCE);
+#endif
+
+// soft knee thresholding
+vec3 softKnee(vec3 color) {
+  float l = Luminance(color.rgb);
+  float x = max(0, l - BLOOM_THRESHOLD + BLOOM_KNEE);
+  color *= mix(x * x / (4 * BLOOM_KNEE), max(0, l - BLOOM_THRESHOLD), float(x > BLOOM_THRESHOLD + BLOOM_KNEE)) / max(l, 1e-6);
+  #if CAP_LUMINANCE > -1
+    color *= min(1.0, maxLuminance / l);
+  #endif
+  return color;
+}
