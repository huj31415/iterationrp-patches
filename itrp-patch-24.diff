+									#ifdef PT_LOWRES_ATLAS
+										atlasCoord = GetAtlasCoordWithLod(voxelCoord, voxelData.xy, voxelDataW.x, hitVoxelPos, hitNormal, atlasPixelSize);
+										voxelColor = textureLod(atlas2D, atlasCoord.xy, atlasCoord.z);
