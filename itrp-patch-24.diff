+							vec2 voxelDataW = Unpack2xU8_from_U16(currVoxelData.w);
+
+							#ifdef PT_LOWRES_ATLAS
+								atlasCoord = GetAtlasCoordWithLod(voxelCoord, currVoxelData.xy, voxelDataW.x, hitVoxelPos, hitNormal, atlasPixelSize);
