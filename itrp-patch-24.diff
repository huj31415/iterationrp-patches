+	// set max coverage to 1
+	// const float coverDeviation = (1 - CLOUD_CLEAR_COVERY);
+	uint weatherSeed = worldDay + 4;
+	vec2 weather = weatherHash(vec2(weatherSeed, weatherSeed + 1));// * 2.0 - 1.0;
+	float weatherBlend = smoothstep(0, 1, worldTime / 24000.0);
+	// blend coverage between days centered around clear coverage setting
+	// influence by load time?
+	float DAILY_COVERAGE = clamp(
+		mix(weather.x, weather.y, weatherBlend), 0.0, 1.0
+	);
+	float FINAL_CLOUD_COVERAGE = mix(DAILY_COVERAGE, CLOUD_RAIN_COVERY, wetness) * 2.0 - 0.5;
+
+	// planar clouds max coverage PC_CLEAR_COVERAGE
+	vec2 PC_weather = weatherHash(vec2(weatherSeed + 0.5, weatherSeed + 1.5));
+	float FINAL_PC_COVERAGE = clamp(
+		mix(PC_weather.x, PC_weather.y, weatherBlend) * PC_CLEAR_COVERAGE, 0.1, 1.0
+	);
